{
  "name": "@repo/runtime",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/esm/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint . --max-warnings 0 && tsc --noEmit --incremental",
