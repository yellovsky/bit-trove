{
  "name": "frontend",
  "version": "1.0.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev --force",
    "eslint": "eslint",
    "typecheck": "tsc --noEmit",
    "lint": "eslint && yarn typecheck",
    "start": "remix-serve ./build/server/index.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest --runInBand"
  },
  "dependencies": {
    "@fontsource-variable/geologica": "^5.1.0",
    "@fontsource-variable/inter": "^5.1.0",
    "@fontsource-variable/manrope": "^5.1.0",
    "@remix-run/node": "^2.13.1",
    "@remix-run/react": "^2.13.1",
    "@remix-run/serve": "^2.13.1",
    "@repo/remix-i18n": "*",
    "@tanstack/react-query": "^5.59.17",
    "@tanstack/react-query-devtools": "^5.59.17",
    "@tanstack/react-table": "^8.20.5",
    "@yornaath/batshit": "^0.10.1",
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "effect": "^3.10.8",
    "eventemitter3": "^5.0.1",
    "history": "^5.3.0",
    "i18next": "^23.16.4",
    "i18next-browser-languagedetector": "^8.0.0",
    "i18next-fs-backend": "^2.3.2",
    "i18next-http-backend": "^2.6.2",
    "isbot": "^5.1.17",
    "multer": "^1.4.5-lts.1",
    "qs": "^6.13.0",
    "ramda": "^0.30.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.1",
    "react-i18next": "^15.1.0",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.6.1",
    "remix-utils": "^7.7.0",
    "uuid": "^11.0.2"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@remix-run/dev": "^2.13.1",
    "@remix-run/testing": "^2.13.1",
    "@repo/api-models": "*",
    "@repo/typescript-config": "*",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.0.1",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/qs": "^6.9.16",
    "@types/ramda": "^0.30.2",
    "@types/react": "^18.3.12",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15",
    "autoprefixer": "^10.4.20",
    "eslint": "9.14.0",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0-beta1",
    "postcss": "^8.4.47",
    "remix-development-tools": "^4.7.5",
    "sass": "^1.80.6",
    "tailwindcss": "^3.4.14",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-tsconfig-paths": "^5.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "coveragePathIgnorePatterns": [
      ".*\\.module\\.ts$"
    ],
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "app",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^~/(.*)$": "<rootDir>/$1"
    }
  }
}
