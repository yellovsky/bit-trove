generator client {
    provider        = "prisma-client-js"
    previewFeatures = ["relationJoins"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Language {
    code String @id @unique

    article_translations ArticleTranslation[]
    articles             Article[]

    @@map("language")
}

model ArticleBlock {
    id                     String   @id @default(uuid())
    article_translation_id String
    title                  String?
    subtitle               String?
    order                  Int
    type                   String
    content                Json
    created_at             DateTime @default(now())
    updated_at             DateTime @updatedAt

    article_translation ArticleTranslation @relation(fields: [article_translation_id], references: [id], onDelete: Cascade)

    @@unique([article_translation_id, order])
    @@map("article_block")
}

model ArticleTranslation {
    id                String    @id @default(uuid())
    created_at        DateTime  @default(now())
    updated_at        DateTime  @updatedAt
    published_at      DateTime?
    language_code     String
    title             String
    article_id        String
    short_description String
    seo_title         String
    seo_description   String
    seo_keywords      String

    language Language       @relation(fields: [language_code], references: [code], onDelete: Restrict)
    article  Article        @relation(fields: [article_id], references: [id], onDelete: Cascade)
    blocks   ArticleBlock[]

    @@unique([article_id, language_code])
    @@map("article_translation")
}

model Article {
    id                     String    @id @default(uuid())
    created_at             DateTime  @default(now())
    updated_at             DateTime  @updatedAt
    published_at           DateTime?
    original_language_code String
    author_id              String?

    translations      ArticleTranslation[]
    blog_post         BlogPost?
    tutorial          Tutorial?
    original_language Language             @relation(fields: [original_language_code], references: [code], onDelete: Restrict)
    author            Account?             @relation(fields: [author_id], references: [id], onDelete: SetNull)

    @@map("article")
}

model BlogPost {
    id           String    @id @default(uuid())
    slug         String    @unique
    created_at   DateTime  @default(now())
    updated_at   DateTime  @updatedAt
    published_at DateTime?
    article_id   String    @unique

    article Article @relation(fields: [article_id], references: [id], onDelete: Cascade)
}

model Tutorial {
    id           String    @id @default(uuid())
    slug         String    @unique
    created_at   DateTime  @default(now())
    updated_at   DateTime  @updatedAt
    published_at DateTime?
    article_id   String    @unique

    article Article @relation(fields: [article_id], references: [id], onDelete: Cascade)
}

model CasbinRule {
    id    Int     @id @default(autoincrement())
    ptype String
    v0    String?
    v1    String?
    v2    String?
    v3    String?
    v4    String?
    v5    String?

    @@map("casbin_rule")
}

model Account {
    id       String @id @default(uuid())
    email    String @unique
    pwd_hash String

    articles Article[]

    @@map("account")
}
